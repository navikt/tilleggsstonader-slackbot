{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "es2017",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./build",
    "allowJs": false,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  }
}
